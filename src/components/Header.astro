---
export interface NavItem {
  label: string;
  href: string;
  hasDropdown?: boolean;
  dropdown?: Array<{ group: string; items: Array<{ label: string; href: string }> }>;
}

const navItems: NavItem[] = [
  { label: 'Home', href: '#' },
  { label: 'Features', href: '#features' },
  { label: 'About', href: '#about' },
  {
    label: 'Pages',
    href: '#',
    hasDropdown: true,
    dropdown: [
      { group: 'Pages', items: [
        { label: 'Blog', href: '#' },
        { label: 'Pricing', href: '#' },
        { label: 'Integrations', href: '#' },
        { label: 'Sign Up', href: '#' },
      ]},
      { group: 'CMS Pages', items: [
        { label: 'Integration Details', href: '#' },
        { label: 'Blog Details', href: '#' },
      ]},
      { group: 'Utility Pages', items: [
        { label: 'Password Protected', href: '#' },
        { label: '404 Page', href: '#' },
        { label: 'Style Guide', href: '#' },
        { label: 'Licenses', href: '#' },
        { label: 'Changelog', href: '#' },
        { label: 'Instruction', href: '#' },
      ]},
    ],
  },
  { label: 'Contact', href: '#contact' },
];
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <svg width="130" height="32" viewBox="0 0 130 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="8" fill="#2563EB"/>
        <text x="8" y="22" font-family="Inter" font-size="16" font-weight="800" fill="#fff">Z</text>
        <text x="44" y="22" font-family="Inter" font-size="18" font-weight="700" fill="#1E293B">arex</text>
      </svg>
    </a>
    <nav class="nav">
      {navItems.map((item) => (
        item.hasDropdown ? (
          <div class="nav-dropdown">
            <span class="nav-link nav-link-dropdown">{item.label} <svg width="10" height="6" viewBox="0 0 10 6"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/></svg></span>
            <div class="dropdown-menu">
              {item.dropdown!.map((group) => (
                <div class="dropdown-group">
                  <div class="dropdown-group-title">{group.group}</div>
                  {group.items.map((sub) => (
                    <a href={sub.href} class="dropdown-item">{sub.label}</a>
                  ))}
                </div>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href} class="nav-link">{item.label}</a>
        )
      ))}
    </nav>
    <div class="header-actions">
      <a href="#" class="btn-text">Sign In</a>
      <a href="#" class="btn btn-primary">Start for Free</a>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }
  .nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  .nav-link {
    font-size: 15px;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.15s;
  }
  .nav-link:hover {
    color: var(--color-primary);
  }
  .nav-link-dropdown {
    display: flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
  }
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown:hover .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: -20px;
    padding: 8px 0;
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    min-width: 600px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: all 0.25s ease;
  }
  .dropdown-group {
    padding: 16px 20px;
  }
  .dropdown-group-title {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }
  .dropdown-item {
    display: block;
    padding: 6px 0;
    font-size: 14px;
    color: var(--color-text-secondary);
  }
  .dropdown-item:hover {
    color: var(--color-primary);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  @media (max-width: 1024px) {
    .nav { display: none; }
  }
  @media (max-width: 768px) {
    .header-inner { height: 60px; }
    .header-actions .btn-text { display: none; }
  }
</style>
