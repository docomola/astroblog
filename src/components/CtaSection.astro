<section class="cta">
  <div class="container">
    <div class="cta-inner">
      <h2 class="cta-title">Grow Your LinkedIn Profile With AI Automation</h2>
      <p class="cta-text">Start generating qualified leads on autopilot. No credit card required.</p>
      <div class="cta-buttons">
        <a href="#" class="btn btn-primary btn-lg">Start for Free</a>
        <a href="#" class="btn btn-outline btn-lg">Book a Demo</a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    padding: 100px 0;
    background: var(--color-bg-white);
  }
  .cta-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }
  .cta-title {
    font-size: 40px;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1.2;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .cta-text {
    font-size: 18px;
    color: var(--color-text-secondary);
    margin-bottom: 36px;
  }
  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 16px;
  }
  @media (max-width: 768px) {
    .cta { padding: 60px 0; }
    .cta-title { font-size: 28px; }
    .cta-buttons { flex-direction: column; align-items: center; }
  }
</style>
