---
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-text">
      <span class="badge badge-blue">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        AI-Powered Growth
      </span>
      <h1 class="hero-title">Generate Leads Faster Than Ever for LinkedIn</h1>
      <p class="hero-subtitle">Supercharge your LinkedIn growth with AI-driven automation. Find qualified leads, engage prospects, and track results — all from one powerful dashboard.</p>
      <div class="hero-buttons">
        <a href="#" class="btn btn-primary btn-lg">Start for Free</a>
        <a href="#" class="btn btn-outline btn-lg">View Demo</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-number">9k+</span>
          <span class="hero-stat-label">Active Users</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-number">+135%</span>
          <span class="hero-stat-label">Growth Rate</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-number">4.8</span>
          <span class="hero-stat-label">Rating</span>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="dashboard-mockup">
        <div class="mockup-bar">
          <span class="mockup-dot"></span>
          <span class="mockup-dot"></span>
          <span class="mockup-dot"></span>
        </div>
        <div class="mockup-content">
          <div class="mockup-card">
            <div class="mockup-card-header">
              <span>Recent Activity</span>
              <span class="mockup-badge-up">+24%</span>
            </div>
            <div class="mockup-bars">
              <div class="mockup-bar-chart" style="height:24px;width:60%"></div>
              <div class="mockup-bar-chart" style="height:36px;width:80%"></div>
              <div class="mockup-bar-chart" style="height:20px;width:45%"></div>
              <div class="mockup-bar-chart" style="height:40px;width:90%"></div>
              <div class="mockup-bar-chart" style="height:30px;width:70%"></div>
            </div>
          </div>
          <div class="mockup-card-small">
            <div class="mockup-stat-big">680k</div>
            <div class="mockup-stat-label">Leads Generated</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 80px 0 60px;
    overflow: hidden;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .hero-title {
    font-size: 56px;
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-secondary);
    margin: 24px 0;
    letter-spacing: -0.03em;
  }
  .hero-subtitle {
    font-size: 18px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 36px;
  }
  .hero-buttons {
    display: flex;
    gap: 16px;
    margin-bottom: 48px;
  }
  .btn-lg {
    padding: 16px 32px;
    font-size: 16px;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 20px 0;
    border-top: 1px solid var(--color-border);
  }
  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0 24px;
  }
  .hero-stat-number {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-secondary);
  }
  .hero-stat-label {
    font-size: 13px;
    color: var(--color-text-muted);
  }
  .hero-stat-divider {
    width: 1px;
    height: 40px;
    background: var(--color-border);
  }
  .hero-visual {
    display: flex;
    justify-content: center;
  }
  .dashboard-mockup {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    width: 100%;
    max-width: 520px;
    overflow: hidden;
  }
  .mockup-bar {
    display: flex;
    gap: 8px;
    padding: 14px 20px;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }
  .mockup-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
  }
  .mockup-content {
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .mockup-card {
    background: var(--color-bg);
    border-radius: var(--radius-sm);
    padding: 20px;
  }
  .mockup-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text);
  }
  .mockup-badge-up {
    font-size: 12px;
    font-weight: 600;
    color: #065F46;
    background: var(--color-accent-light);
    padding: 4px 10px;
    border-radius: var(--radius-full);
  }
  .mockup-bars {
    display: flex;
    align-items: flex-end;
    gap: 12px;
    height: 44px;
  }
  .mockup-bar-chart {
    background: var(--color-primary);
    border-radius: 4px 4px 0 0;
    opacity: 0.6;
    flex: 1;
  }
  .mockup-card-small {
    background: linear-gradient(135deg, var(--color-primary-dark), var(--color-primary));
    border-radius: var(--radius-sm);
    padding: 24px;
    text-align: center;
    color: #fff;
  }
  .mockup-stat-big {
    font-size: 36px;
    font-weight: 800;
  }
  .mockup-stat-label {
    font-size: 13px;
    opacity: 0.85;
    margin-top: 4px;
  }
  @media (max-width: 1024px) {
    .hero-title { font-size: 40px; }
    .hero-grid { gap: 40px; }
  }
  @media (max-width: 768px) {
    .hero { padding: 48px 0 40px; }
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .hero-title { font-size: 34px; }
    .hero-stats { gap: 16px; flex-wrap: wrap; }
    .hero-stat-divider { display: none; }
  }
</style>
